    {
        "id": "8f32a2c20ce1d0ec",
        "type": "function",
        "z": "ab1b0ea518202bba",
        "name": "function 5",
        "func": "const parts = msg.topic.split(\"/\");\n\nconst environment_id = parts[1];\nconst wastebin_id = parts[3];\nconst device_id = parts[5];\n\nlet counts = flow.get(\"counts\") || {};\n\nif (!counts[wastebin_id]) {\n    counts[wastebin_id] = [];\n}\n\nconst now = Date.now();\n\ncounts[wastebin_id].push(now);\n\ncounts[wastebin_id] = counts[wastebin_id].filter(\n    t => now - t < 2 * 60 * 1000\n);\n\nconst event_count = counts[wastebin_id].length;\n\nflow.set(\"counts\", counts);\n\nlet activity_level = \"low\";\n\nif (event_count > 10) {\n    activity_level = \"high\";\n}\nelse if (event_count > 5) {\n    activity_level = \"medium\";\n}\n\nmsg.payload = {\n    wastebin_id: wastebin_id,\n    activity_level: activity_level,\n    event_count: event_count\n};\n\nmsg.topic = `smartbin/${msg.payload.wastebin_id}/usage/nodered`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 260,
        "wires": [
