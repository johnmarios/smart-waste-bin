        "func": "const ts = new Date(msg.payload.evaluation_timestamp);\n\n\nmsg.payload =\n    \"--------------------------------------------------\" +\n    \"\\nActivity Level: \" + msg.payload.activity_level +\n    \"\\nEvent Count: \" + msg.payload.event_count +\n    \"\\nWindow Size: \" + msg.payload.window_size_minutes + \" min\" +\n    \"\\nTime: \" + ts.toLocaleString(\"el-GR\", {\n        timeZone: \"Europe/Athens\"\n    }) +\n    \"\\n\";\n\nreturn msg;",
