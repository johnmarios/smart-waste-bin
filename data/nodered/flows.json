    {
        "id": "1f1c7a31bde58a5e",
        "type": "function",
        "z": "ab1b0ea518202bba",
        "name": "function 1",
        "func": "const parts = msg.topic.split(\"/\");\n\nconst environment_id = parts[1];\nconst wastebin_id = parts[3];\nconst device_id = parts[5];\n\n// Get existing per-bin logs\nlet logs = flow.get(\"motion_events\") || {};\n\n// Initialize bin log if needed\nif (!logs[wastebin_id]) {\n    logs[wastebin_id] = [];\n}\n\nconst currentTime = Date.now();\n\nconst windowSizeMinutes = 2;\nconst timeWindow = windowSizeMinutes * 60 * 1000;\n\n// Add new event timestamp ONLY for this bin\nlogs[wastebin_id].push(currentTime);\n\n// Keep only recent events for this bin\nlogs[wastebin_id] = logs[wastebin_id].filter(eventTime => {\n    return (currentTime - eventTime) < timeWindow;\n});\n\n// Save updated logs\nflow.set(\"motion_events\", logs);\n\n// Count events ONLY for this bin\nconst eventCount = logs[wastebin_id].length;\n\nlet activityLevel;\n\n// Determine activity level\nif (eventCount === 0) {\n    activityLevel = \"idle\";\n}\nelse if (eventCount <= 5) {\n    activityLevel = \"low\";\n}\nelse if (eventCount <= 10) {\n    activityLevel = \"medium\";\n}\nelse {\n    activityLevel = \"high\";\n}\n\n// KEEP ORIGINAL PAYLOAD FORMAT\nmsg.payload = {\n    wastebin_id: wastebin_id,\n    activity_level: activityLevel,\n    event_count: eventCount,\n    window_size_minutes: windowSizeMinutes,\n    evaluation_timestamp: new Date(currentTime).toISOString()\n};\n\n// Dynamic topic\nmsg.topic = `smartbin/${wastebin_id}/alerts`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 300,
        "wires": [
            [
                "c0c55b5e868ab60c",
                "322df7dccf748bef",
                "5d82c7a112eaa9a6",
                "84b8e47f1b5bcdcc"
            ]
        ]
